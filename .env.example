# Anthropic API key — leave unset to run in demo mode (canned agent responses)
ANTHROPIC_API_KEY=your_key_here

# Neon PostgreSQL (asyncpg driver) — leave unset to use in-memory storage for local demo
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname

ENVIRONMENT=development

# Force demo mode even when an API key is present
DEMO_MODE=false
